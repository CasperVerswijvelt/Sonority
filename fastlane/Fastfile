# Fastlane lanes to build + upload Sonority to TestFlight / the App Store.
#
# Auth: an App Store Connect API key (no Apple ID 2FA). Put the key id, issuer
# id, and .p8 path in fastlane/.env (see .env.example).
#
# Signing — two paths, picked automatically by is_ci:
#   * Local: Xcode *automatic* signing (Team set on the Runner targets) +
#     `-allowProvisioningUpdates`, so the API key creates/fetches profiles. No
#     match repo needed to build from your own Mac.
#   * CI: fastlane *match* — fetch the shared cert+profile (readonly) from the
#     private certs repo and switch Release to *manual* signing. This avoids
#     minting a new distribution cert on every ephemeral runner (Apple caps you
#     at ~2-3). Populate the repo once with the `certificates` lanes below.
#
# Run from the repo root:
#   bundle exec fastlane ios beta        # build + upload to TestFlight
#   bundle exec fastlane ios release     # build + submit for App Store review
#   bundle exec fastlane mac beta / release
#   bundle exec fastlane ios certificates  # (one-time) create/refresh match repo
#   bundle exec fastlane mac certificates
#
# Prereqs: enrollment complete, Team set in Xcode, PrivacyInfo.xcprivacy in the
# Runner targets, app records in App Store Connect, and — for CI — the match repo
# populated + secrets set (see docs/PUBLISHING-APPLE.md).

# fvm-managed Flutter (this machine — see CLAUDE.md). CI sets FLUTTER_BIN=flutter.
FLUTTER = ENV["FLUTTER_BIN"] || File.expand_path("~/fvm/versions/3.44.6/bin/flutter")

APP_ID = "be.casperverswijvelt.sonority"
# iOS-only WidgetKit extension embedded in Runner; needs its own App Store profile.
WIDGET_APP_ID = "be.casperverswijvelt.sonority.ProfileWidget"
TEAM_ID = "V95M6HBV65"

# The provisioning-profile name match installs differs per platform (macOS gets a
# " macos" suffix) and per app id. match exports it into ENV after it runs; fall
# back to the documented naming if absent.
def match_profile_name(platform, app_id = APP_ID)
  suffix = platform == "macos" ? "_macos" : ""
  ENV["sigh_#{app_id}#{suffix}_profile-name"] ||
    "match AppStore #{app_id}#{platform == "macos" ? " macos" : ""}"
end

def asc_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_filepath: ENV.fetch("ASC_KEY_FILEPATH"),
    in_house: false,
  )
end

# Run Flutter in the pre-bundler env. Under `bundle exec` the bundler GEM_HOME/PATH
# shadows Homebrew's CocoaPods, so flutter's shell-out reports "CocoaPods installed
# but broken" and skips pod install. with_unbundled_env restores the working pod.
def flutter_build(args)
  Bundler.with_unbundled_env { sh("#{FLUTTER} #{args}") }
end

# gym/build_app has no api_key option, so the App Store Connect key has to reach
# xcodebuild directly for automatic provisioning (-allowProvisioningUpdates).
# Without these it falls back to the Apple ID logged into Xcode and fails.
def prov_xcargs
  # ASC_KEY_FILEPATH is anchored at the repo root (../from this fastlane dir);
  # expand against it so cwd at eval time can't double the path.
  key_path = File.expand_path(ENV.fetch("ASC_KEY_FILEPATH"), File.expand_path("..", __dir__))
  "-allowProvisioningUpdates " \
    "-authenticationKeyPath #{key_path} " \
    "-authenticationKeyID #{ENV.fetch("ASC_KEY_ID")} " \
    "-authenticationKeyIssuerID #{ENV.fetch("ASC_ISSUER_ID")}"
end

# CI only: prepare a temp keychain, fetch the shared signing assets from the
# match repo (readonly), and switch Release to manual signing pointed at them.
# No-op locally, so local builds keep using automatic signing.
def ci_signing(platform)
  return unless is_ci

  setup_ci
  match(
    type: "appstore",
    platform: platform,
    readonly: true,
    api_key: asc_key,
    # The Matchfile lists both app ids, but ProfileWidget is an iOS-only extension
    # (no macOS target/profile) — so macOS match must fetch the app profile only,
    # else it fails looking for a nonexistent macOS widget profile.
    app_identifier: platform == "macos" ? [APP_ID] : [APP_ID, WIDGET_APP_ID],
    additional_cert_types: platform == "macos" ? ["mac_installer_distribution"] : nil,
  )
  proj = platform == "macos" ? "macos/Runner.xcodeproj" : "ios/Runner.xcodeproj"
  update_code_signing_settings(
    use_automatic_signing: false,
    path: proj,
    team_id: TEAM_ID,
    code_sign_identity: "Apple Distribution",
    profile_name: match_profile_name(platform),
    targets: ["Runner"],
    build_configurations: ["Release"],
  )
  # iOS embeds the ProfileWidget app extension — sign it with its OWN profile
  # (a per-target call; profile_name can't map two bundle ids at once).
  if platform == "ios"
    update_code_signing_settings(
      use_automatic_signing: false,
      path: proj,
      team_id: TEAM_ID,
      code_sign_identity: "Apple Distribution",
      profile_name: match_profile_name(platform, WIDGET_APP_ID),
      targets: ["ProfileWidget"],
      build_configurations: ["Release"],
    )
  end
end

# One build_app config for both platforms; adds CI-only manual export options.
def archive_apple(platform)
  opts = {
    workspace: platform == "macos" ? "macos/Runner.xcworkspace" : "ios/Runner.xcworkspace",
    scheme: "Runner",
    export_method: "app-store",
    output_directory: platform == "macos" ? "build/fastlane-macos" : "build/fastlane-ios",
    xcargs: prov_xcargs,
  }
  opts[:export_team_id] = TEAM_ID if platform == "macos" # "No Team Found in Archive" otherwise
  if is_ci
    profiles = { APP_ID => match_profile_name(platform) }
    # iOS export must also map the embedded ProfileWidget extension's profile.
    profiles[WIDGET_APP_ID] = match_profile_name(platform, WIDGET_APP_ID) if platform == "ios"
    opts[:export_options] = {
      signingStyle: "manual",
      provisioningProfiles: profiles,
    }
  end
  build_app(opts)
end

# Upload to TestFlight and push to the external "External" group (its public link
# is the one in the README). distribute_external submits the build for Beta App
# Review and, once processing finishes, assigns it to the group — so we can't
# skip waiting for processing here (unlike an internal-only upload).
def distribute_testflight(key)
  upload_to_testflight(
    api_key: key,
    distribute_external: true,
    groups: ["External"],
    notify_external_testers: true,
    changelog: "Automated CI build — see the GitHub release notes for what's new.",
  )
end

platform :ios do
  desc "Create/refresh the shared iOS signing assets in the match repo"
  # Pass force:true to re-issue profiles even when the existing ones are still
  # valid — needed after enabling a new App ID capability (e.g. multicast),
  # since match won't otherwise notice the entitlement drift.
  lane :certificates do |options|
    match(type: "appstore", platform: "ios", readonly: false, api_key: asc_key,
          force: options[:force] || false)
  end

  desc "Build and upload an iOS build to TestFlight"
  lane :beta do
    key = asc_key
    ci_signing("ios")
    flutter_build("build ios --release --no-codesign")
    archive_apple("ios")
    distribute_testflight(key)
  end

  desc "Build and submit the iOS app for App Store review"
  lane :release do
    key = asc_key
    ci_signing("ios")
    flutter_build("build ios --release --no-codesign")
    archive_apple("ios")
    upload_to_app_store(
      api_key: key,
      submit_for_review: true,
      automatic_release: false,
      force: true,                       # skip the HTML metadata preview prompt
      precheck_include_in_app_purchases: false,
      submission_information: { add_id_info_uses_idfa: false },
    )
  end
end

platform :mac do
  desc "Create/refresh the shared macOS signing assets in the match repo"
  lane :certificates do
    # App Store distribution cert (+ installer) for TestFlight / Mac App Store.
    # app_identifier: [APP_ID] only — the widget is iOS-only, so don't try to
    # create a macOS widget profile (see ci_signing).
    match(type: "appstore", platform: "macos", readonly: false, api_key: asc_key,
          app_identifier: [APP_ID],
          additional_cert_types: ["mac_installer_distribution"])
    # NB: the Developer ID Application cert (for the notarized .dmg) canNOT be
    # created via the App Store Connect API — Apple restricts creation to the
    # Account Holder, via the Developer portal or Xcode. Create it once there,
    # export a .p12, then import it into the match repo (see docs/PUBLISHING-APPLE.md):
    #   fastlane match import --type developer_id --platform macos --api_key_path <key.json>
    # After that, `mac github` fetches it readonly.
  end

  desc "Build and upload a macOS build to TestFlight"
  lane :beta do
    key = asc_key
    ci_signing("macos")
    flutter_build("build macos --release")
    archive_apple("macos")
    distribute_testflight(key)
  end

  desc "Build a Developer ID-signed + notarized .dmg for direct download (GitHub Release)"
  lane :github do
    # Developer ID signing. NOT via match: match requires an empty-passphrase p12
    # and authenticates to the portal on import, both awkward for CI. Instead the
    # identity is a single secret (MACOS_DEVID_P12_BASE64 / _PASSWORD) imported
    # straight into the CI keychain. Locally the identity is in your login keychain.
    if is_ci
      setup_ci
      p12 = File.join(Dir.tmpdir, "devid_ci.p12")
      sh("printf '%s' \"$MACOS_DEVID_P12_BASE64\" | base64 --decode > #{p12.shellescape}")
      import_certificate(
        certificate_path: p12,
        certificate_password: ENV.fetch("MACOS_DEVID_P12_PASSWORD"),
        keychain_name: ENV.fetch("MATCH_KEYCHAIN_NAME", "fastlane_tmp_keychain"),
        keychain_password: ENV.fetch("MATCH_KEYCHAIN_PASSWORD", ""),
      )
      File.delete(p12)
      update_code_signing_settings(
        use_automatic_signing: false,
        path: "macos/Runner.xcodeproj",
        team_id: TEAM_ID,
        code_sign_identity: "Developer ID Application",
        profile_name: "",
        targets: ["Runner"],
        build_configurations: ["Release"],
      )
    end

    flutter_build("build macos --release")

    # Archive + export a Developer-ID app with the Hardened Runtime enabled
    # (notarization rejects apps without it).
    app = build_app(
      workspace: "macos/Runner.xcworkspace",
      scheme: "Runner",
      export_method: "developer-id",
      output_directory: "build/fastlane-macos-devid",
      export_team_id: TEAM_ID,
      xcargs: "#{prov_xcargs} ENABLE_HARDENED_RUNTIME=YES",
    )

    # Package the exported .app into a styled drag-to-Applications .dmg (black
    # background + grey arrow + SONORITY wordmark, see tool/dmg_background.swift),
    # notarize it with the ASC API key, then staple the ticket so it opens offline
    # without a Gatekeeper prompt. notarytool/stapler are xcrun'd directly (robust
    # across fastlane versions).
    tag = ENV["RELEASE_TAG"] || "dev"
    dmg = File.expand_path("../dist/Sonority-#{tag}-macos.dmg", __dir__)
    key_path = File.expand_path(ENV.fetch("ASC_KEY_FILEPATH"), File.expand_path("..", __dir__))
    bg = File.expand_path("../macos/dmg/background.png", __dir__)
    stage = File.join(Dir.tmpdir, "sonority-dmg-src")
    sh("mkdir -p #{File.dirname(dmg).shellescape}")
    # create-dmg copies the source *folder's* contents, so stage a dir holding
    # only Sonority.app (else stray export files land in the window).
    sh("rm -rf #{stage.shellescape} && mkdir -p #{stage.shellescape}")
    sh("cp -R '#{app}' #{stage.shellescape}/")
    sh("rm -f '#{dmg}'") # create-dmg refuses to overwrite an existing output
    sh("create-dmg " \
       "--volname Sonority " \
       "--background '#{bg}' " \
       "--window-pos 200 120 --window-size 600 430 --icon-size 128 " \
       "--icon 'Sonority.app' 150 165 " \
       "--app-drop-link 450 165 " \
       "--hdiutil-quiet " \
       "'#{dmg}' #{stage.shellescape}")
    sh("xcrun notarytool submit '#{dmg}' " \
       "--key '#{key_path}' --key-id '#{ENV.fetch("ASC_KEY_ID")}' " \
       "--issuer '#{ENV.fetch("ASC_ISSUER_ID")}' --wait")
    sh("xcrun stapler staple '#{dmg}'")
  end

  desc "Build and submit the macOS app for App Store review"
  lane :release do
    key = asc_key
    ci_signing("macos")
    flutter_build("build macos --release")
    archive_apple("macos")
    upload_to_app_store(
      api_key: key,
      submit_for_review: true,
      automatic_release: false,
      force: true,
    )
  end
end
