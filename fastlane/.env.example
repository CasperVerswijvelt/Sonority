# Copy to fastlane/.env (gitignored) and fill in.
#
# Create the key once enrollment is done: App Store Connect → Users and Access →
# Integrations → App Store Connect API → Team Keys → (+) → role "Admin" (Admin is
# required to create distribution certificates; App Manager can't). Download the
# AuthKey_XXXXXXXXXX.p8 (one-time download!) and note the Key ID and the Issuer ID
# shown at the top of that page.

ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASC_KEY_FILEPATH=./fastlane/AuthKey_XXXXXXXXXX.p8

# fastlane match — shared signing assets in a PRIVATE git repo (used by CI; also
# how you generate certs locally with the `certificates` lanes). Create an empty
# private repo, then:
MATCH_GIT_URL=git@github.com:CasperVerswijvelt/Sonority-certs.git
MATCH_PASSWORD=choose-a-strong-passphrase

# Optional: pin the Flutter binary (defaults to the fvm path in the Fastfile).
# FLUTTER_BIN=/Users/you/fvm/versions/3.44.6/bin/flutter
