<?xml version="1.0" encoding="utf-8"?>
<!-- Neutral rounded container (adapts light/dark, fixed widget_bg_radius to match
     the iOS widget) holding a weight-filled grid of tonal profile tiles. The grid
     is a vertical LinearLayout the provider fills with weighted rows (see
     ProfileWidgetProvider) — tiles split width/height by layout_weight, so they
     fill the widget exactly at any size with no pixel-size guessing. The 4dp grid
     padding + 4dp tile margins add up to a uniform 8dp gap (= widget_bg_radius −
     widget_tile_radius, so tiles nest concentrically). @android:id/background lets
     the launcher auto-clip us. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@android:id/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_container">
    <LinearLayout
        android:id="@+id/grid"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="4dp" />
    <TextView
        android:id="@+id/empty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:padding="12dp"
        android:text="Tap to pick profiles"
        android:textColor="?android:attr/textColorSecondary" />
</FrameLayout>
